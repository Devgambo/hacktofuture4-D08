# Never ship secrets or local runtime state into the image
.env
.env.*
!.env.example
repo_tokens.json
sessions.json
webhook_store.json

# Python / build caches
.venv
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Node (only npx is used at runtime; no local node_modules needed)
node_modules
package-lock.json
