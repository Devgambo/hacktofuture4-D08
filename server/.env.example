# ── OpenAI ────────────────────────────────────────────────
# Used for all LLM calls (fix generation, PR review) and embeddings.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ── GitHub OAuth App ─────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL must match PUBLIC_BASE_URL below, e.g.
#   http://localhost:8000/api/auth/callback  (dev)
#   https://api.example.com/api/auth/callback (prod)
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

# ── GitHub Webhook ────────────────────────────────────────
# A secret string YOU choose — must match what you set on the webhook
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── GitHub Personal Access Token (fallback PAT, optional) ─
GITHUB_TOKEN=your_github_pat_here

# ── PostgreSQL / Neon ─────────────────────────────────────
# Get from https://console.neon.tech/
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── App Environment ───────────────────────────────────────
# Set to "production" to enable secure cookies (HTTPS only) and to require
# TOKEN_ENCRYPTION_KEY below.
APP_ENV=development
LOG_LEVEL=info

# Session cookie SameSite policy: lax | none | strict
#   lax  — frontend & backend share a domain (app.example.com + api.example.com)
#   none — frontend & backend on different sites (e.g. *.vercel.app + AWS); HTTPS only
COOKIE_SAMESITE=lax

# ── Public URLs (OAuth redirects + CORS) ──────────────────
# Public base URL of THIS backend (used to build the OAuth callback).
PUBLIC_BASE_URL=http://localhost:8000
# Public base URL of the frontend (used for post-login / logout redirects).
FRONTEND_BASE_URL=http://localhost:5173
# Comma-separated list of allowed CORS origins. Leave empty for local dev
# (defaults to the Vite dev servers). In production set to your frontend origin,
# e.g. https://app.example.com  — or leave empty when served same-origin via nginx.
CORS_ORIGINS=

# ── Token encryption ──────────────────────────────────────
# REQUIRED in production. Encrypts GitHub tokens stored in PostgreSQL.
# Generate once and keep stable:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# ── Webhook Base URL ──────────────────────────────────────
# Public HTTPS URL that GitHub sends webhooks to (e.g. your ngrok URL or domain)
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── Telegram Bot (optional) ───────────────────────────────
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here
# Public HTTPS URL that Telegram will call for updates
TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/api/webhooks/telegram

# Comma-separated Telegram user IDs to *allow* to interact with the bot.
# Leave empty to allow any Telegram user to run /link.
# NOTE: This is an access-control list, NOT the notification target.
# Targeted notifications are configured per-user: after logging in via GitHub,
# each user sends "/link <github-username>" to the bot to receive their own alerts.
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id_here

# ---------------------------------------------------------
# Agent Settings
# ---------------------------------------------------------

# PR review confidence threshold for Auto-merge (bypass telegram)
PR_REVIEW_AUTO_MERGE_THRESHOLD=75
# PR review confidence threshold for manual action (bypass fix agent)
PR_REVIEW_MANUAL_THRESHOLD=50

# LLM model ids (optional — defaults shown). Must be models your OPENAI_API_KEY
# can access.
CODING_MODEL_ID=gpt-4o
REASONING_MODEL_ID=gpt-4o-mini
FAST_MODEL_ID=gpt-4o-mini

# ---------------------------------------------------------
# CD Failure Monitoring
# ---------------------------------------------------------
# Shared secret for authenticating CD pipeline webhooks
CD_WEBHOOK_SECRET=your_cd_webhook_secret_here

# AWS (optional — enables CloudWatch log enrichment)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure (optional — enables Azure Monitor enrichment)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# GCP (optional — enables Cloud Logging enrichment)
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
