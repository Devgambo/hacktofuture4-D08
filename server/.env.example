# ── OpenRouter ────────────────────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── GitHub OAuth App ─────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: http://localhost:8000/api/auth/callback
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

# ── GitHub Webhook ────────────────────────────────────────
# A secret string YOU choose — must match what you set on the webhook
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── GitHub Personal Access Token (fallback PAT, optional) ─
GITHUB_TOKEN=your_github_pat_here

# ── PostgreSQL / Neon ─────────────────────────────────────
# Get from https://console.neon.tech/
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── App Environment ───────────────────────────────────────
# Set to "production" to enable secure cookies (HTTPS only)
APP_ENV=development
LOG_LEVEL=info

# ── Webhook Base URL ──────────────────────────────────────
# Public HTTPS URL that GitHub sends webhooks to (e.g. your ngrok URL)
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── Telegram Bot (optional) ───────────────────────────────
# Create a bot at https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here
# Public HTTPS URL that Telegram will call for updates
TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/api/webhooks/telegram

# Comma-separated Telegram user IDs to *allow* to interact with the bot.
# Leave empty to allow any Telegram user to run /link.
# NOTE: This is an access-control list, NOT the notification target.
# Targeted notifications are configured per-user: after logging in via GitHub,
# each user sends "/link <github-username>" to the bot to receive their own alerts.
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id_here

# ── AWS CD Pipeline Error Detection (optional) ───────────
# Required only if you want CloudWatch P99 metric fetching.
# Leave blank when running on EC2/ECS — credentials come from the instance role.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
# Only needed for temporary STS credentials (AssumeRole)
# AWS_SESSION_TOKEN=

# CloudWatch Logs group where CloudTrail delivers IAM events.
# Enables P99 IAM AccessDenied error rate metric.
# Example: aws-cloudtrail-logs-123456789012-us-east-1
AWS_CLOUDTRAIL_LOG_GROUP=

# ---------------------------------------------------------
# Agent Settings
# ---------------------------------------------------------

# PR review confidence threshold for Auto-merge (bypass telegram)
PR_REVIEW_AUTO_MERGE_THRESHOLD=75
# PR review confidence threshold for manual action (bypass fix agent)
PR_REVIEW_MANUAL_THRESHOLD=50
